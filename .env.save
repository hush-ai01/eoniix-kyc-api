Eoniix KYC API — Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in your values. Never commit .env to git.

# Server
PORT=3000
NODE_ENV=development

# Supabase (your existing project)
SUPABASE_URL=https://ghtlzpchjqhxxmqazhnr.supabase.co

# Dojah (get keys from app.dojah.io → API Keys)
DOJAH_BASE_URL=https://api.dojah.io
# Set to 'sandbox' for testing, 'live' for production
DOJAH_ENV=sandbox

# Polygon ID Issuer Node (your existing setup)
POLYGON_ID_ISSUER_URL=http://localhost:3001
POLYGON_ID_ISSUER_DID=did:polygonid:your-issuer-did

# API Security


# Rate limiting (requests per 15 minutes per IP)
RATE_LIMIT_MAX=100
                                            [ Read 24 lines ]
^G Help        ^O Write Out   ^W Where Is    ^K Cut         ^T Execute     ^C Location    M-U Undo
