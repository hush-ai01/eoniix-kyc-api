# ─── Eoniix KYC API — Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in your values. Never commit .env to git.

# Server
PORT=3000
NODE_ENV=development

# Supabase (your existing project)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Dojah (get keys from app.dojah.io → API Keys)
DOJAH_APP_ID=your-dojah-app-id
DOJAH_PRIVATE_KEY=your-dojah-private-key
DOJAH_BASE_URL=https://api.dojah.io
# Set to 'sandbox' for testing, 'live' for production
DOJAH_ENV=sandbox

# Polygon ID Issuer Node (your existing setup)
POLYGON_ID_ISSUER_URL=http://localhost:3001
POLYGON_ID_ISSUER_DID=did:polygonid:your-issuer-did

# API Security
API_KEY_SECRET=generate-a-random-32-char-string-here

# Rate limiting (requests per 15 minutes per IP)
RATE_LIMIT_MAX=100

# Solana Attestation Service
SOLANA_NETWORK=devnet
SOLANA_ISSUER_KEYPAIR_PATH=./sove-issuer-keypair.json
SOLANA_CREDENTIAL_ADDRESS=
SOLANA_SCHEMA_ADDRESS=
