# Eoniix KYC API environment variables
# Copy this file to .env and fill in your values. Never commit .env to git.

# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=
JSON_BODY_LIMIT=10kb

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Dojah
DOJAH_APP_ID=your-dojah-app-id
DOJAH_PRIVATE_KEY=your-dojah-private-key
DOJAH_BASE_URL=https://api.dojah.io
# Set to "sandbox" for testing and "live" only after production approval.
DOJAH_ENV=sandbox

# API key hashing pepper. Do not use this as an admin login token.
API_KEY_SECRET=generate-a-random-32-byte-secret-here

# Admin access
ADMIN_API_KEYS=admin_key_1,admin_key_2
ADMIN_TOKEN=generate-a-separate-admin-token-here

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_PER_KEY_MAX=100

# Solana Attestation Service
SOLANA_NETWORK=devnet
SOLANA_ISSUER_KEYPAIR_PATH=./sove-issuer-keypair.json
SOLANA_CREDENTIAL_ADDRESS=
SOLANA_SCHEMA_ADDRESS=

# Optional live test settings. Leave unset for normal local/CI tests.
TEST_BASE_URL=
TEST_API_KEY=
